{
    "gateway": {
        "auth": {
            "token": "__GATEWAY_TOKEN__"
        },
        "controlUi": {
            "dangerouslyAllowHostHeaderOriginFallback": true,
            "dangerouslyDisableDeviceAuth": true
        }
    },
    "models": {
        "mode": "merge",
        "providers": {
            "hongmacc": {
                "baseUrl": "https://hongmacc.com/api",
                "apiKey": "__HONGMACC_API_KEY__",
                "api": "anthropic-messages",
                "headers": {
                    "User-Agent": "Mozilla/5.0"
                },
                "models": [
                    {
                        "id": "claude-opus-4-6",
                        "name": "Claude Opus 4.6",
                        "reasoning": false,
                        "input": [
                            "text",
                            "image"
                        ],
                        "cost": {
                            "input": 0,
                            "output": 0,
                            "cacheRead": 0,
                            "cacheWrite": 0
                        },
                        "contextWindow": 200000,
                        "maxTokens": 16384
                    },
                    {
                        "id": "claude-sonnet-4-6",
                        "name": "Claude Sonnet 4.6",
                        "reasoning": false,
                        "input": [
                            "text",
                            "image"
                        ],
                        "cost": {
                            "input": 0,
                            "output": 0,
                            "cacheRead": 0,
                            "cacheWrite": 0
                        },
                        "contextWindow": 200000,
                        "maxTokens": 8192
                    }
                ]
            },
            "hongmacc-openai": {
                "baseUrl": "https://hongmacc.com/api",
                "apiKey": "__HONGMACC_API_KEY__",
                "api": "openai-completions",
                "headers": {
                    "User-Agent": "Mozilla/5.0"
                },
                "models": [
                    {
                        "id": "gpt-5.2-codex",
                        "name": "GPT-5.2 Codex",
                        "reasoning": false,
                        "input": [
                            "text",
                            "image"
                        ],
                        "cost": {
                            "input": 0,
                            "output": 0,
                            "cacheRead": 0,
                            "cacheWrite": 0
                        },
                        "contextWindow": 200000,
                        "maxTokens": 16384
                    }
                ]
            },
            "hongmacc-google": {
                "baseUrl": "https://hongmacc.com/api",
                "apiKey": "__HONGMACC_API_KEY__",
                "api": "openai-completions",
                "headers": {
                    "User-Agent": "Mozilla/5.0"
                },
                "models": [
                    {
                        "id": "gemini-3.1-pro-preview",
                        "name": "Gemini 3.1 Pro Preview",
                        "reasoning": false,
                        "input": [
                            "text",
                            "image"
                        ],
                        "cost": {
                            "input": 0,
                            "output": 0,
                            "cacheRead": 0,
                            "cacheWrite": 0
                        },
                        "contextWindow": 200000,
                        "maxTokens": 16384
                    }
                ]
            }
        }
    },
    "agents": {
        "defaults": {
            "model": {
                "primary": "hongmacc/claude-opus-4-6",
                "fallbacks": [
                    "hongmacc/claude-sonnet-4-6",
                    "hongmacc-openai/gpt-5.2-codex",
                    "hongmacc-google/gemini-3.1-pro-preview"
                ]
            },
            "workspace": "/home/ubuntu/.openclaw/workspace",
            "maxConcurrent": 4,
            "subagents": {
                "maxConcurrent": 8
            }
        },
        "list": [
            {
                "id": "main",
                "workspace": "/home/ubuntu/.openclaw/workspace",
                "model": {
                    "primary": "hongmacc/claude-opus-4-6",
                    "fallbacks": [
                        "hongmacc/claude-sonnet-4-6",
                        "hongmacc-openai/gpt-5.2-codex",
                        "hongmacc-google/gemini-3.1-pro-preview"
                    ]
                }
            },
            {
                "id": "dev",
                "workspace": "/home/ubuntu/.openclaw/workspace-dev",
                "model": {
                    "primary": "hongmacc/claude-sonnet-4-6"
                }
            }
        ]
    }
}